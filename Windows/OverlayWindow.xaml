<Window x:Class="GazeStream.Windows.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:GazeStream.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:eye="clr-namespace:GazeStream.Eyetracker"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        IsHitTestVisible="False"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowState="Maximized"
        WindowStartupLocation="Manual" 
        mc:Ignorable="d"
        d:Height="1080" 
        d:Width="1920">
    <Grid Opacity="1">
        <eye:GazeButton x:Name="Intelligaze_Button" HorizontalAlignment="Right" VerticalAlignment="Bottom" Width="150" Height="150" Margin="0,0,40,100" Visibility="Collapsed">
            <eye:GazeButton.Content>
                <Button Style="{StaticResource Gaze}" Click="Intelligaze_Click">
                    <Button.Content>
                        <Grid>
                            <Image Width="64" Height="64" HorizontalAlignment="Center" VerticalAlignment="Center" Source="/Resources/Icons/view.png"/>
                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Bottom" FontSize="22" FontWeight="SemiBold" Text="Intelligaze"/>
                        </Grid>
                    </Button.Content>
                </Button>
            </eye:GazeButton.Content>
        </eye:GazeButton>
        
        
    <Canvas x:Name="RootCanvas" IsHitTestVisible="False">
        <controls:GazeCursor x:Name="Cursor" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"/>
    </Canvas>
    </Grid>
</Window>
