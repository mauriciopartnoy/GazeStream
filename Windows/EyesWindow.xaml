<Window x:Class="GazeStream.Windows.EyesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GazeStream.Windows"
        xmlns:controls="clr-namespace:GazeStream.Controls"
        xmlns:eye="clr-namespace:GazeStream.Eyetracker"
        mc:Ignorable="d"
        Title="CalibrationWindow"  
        WindowState="Maximized"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        ShowInTaskbar="True"
        Topmost="False">
    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="{StaticResource SeriousBackground}">
        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
            <controls:EyeDisplay x:Name="EyeDisplay" Width="484" Height="484"/>
            
            <Image x:Name="CameraDisplay" Width="484" Height="484" Stretch="Fill"/>

            <UniformGrid Background="Transparent" Rows="1" Width="484" Height="200" Margin="0,10,0,10">
                <eye:GazeButton>
                    <Button Style="{StaticResource Serious}" Content="Cambiar Vista" Click="Button_CambiarVista" />
                </eye:GazeButton>
                <eye:GazeButton>
                    <Button Style="{StaticResource Serious}" Content="Salir" Click="Button_Salir"/>
                </eye:GazeButton>
            </UniformGrid>
        </StackPanel>

    </Grid>
</Window>
