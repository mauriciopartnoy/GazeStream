<UserControl x:Class="GazeStream.Controls.EnumSelector"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:eye="clr-namespace:GazeStream.Eyetracker"
             x:Name="root">

    <ItemsControl ItemsSource="{Binding EnumValues, ElementName=root}">

        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal"/>
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>

        <ItemsControl.ItemTemplate>
            <DataTemplate>

                <eye:GazeButton>

                    <RadioButton
        Style="{StaticResource EnumSelectorRadioStyle}"
        Content="{Binding}"
        Tag="{Binding}"
        GroupName="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=Uid}"
        Checked="RadioButton_Checked"
        Loaded="RadioButton_Loaded"/>

                </eye:GazeButton>

            </DataTemplate>

        </ItemsControl.ItemTemplate>

    </ItemsControl>

</UserControl>