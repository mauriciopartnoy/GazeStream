<UserControl x:Class="GazeStream.Controls.ScrollPageControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GazeStream.Controls"
             xmlns:eye="clr-namespace:GazeStream.Eyetracker"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <StackPanel Orientation="Vertical">
        <eye:GazeButton Width="200" Height="200" Margin="10,10,10,10" RepeatAction="True">
            <Button FontSize="48" Content="▲" Click="ScrollUp">
                
            </Button>
        </eye:GazeButton>
        <eye:GazeButton Width="200" Height="200" Margin="10,10,10,10" RepeatAction="True">
            <Button FontSize="48" Content="▼" Click="ScrollDown">
                
            </Button>
        </eye:GazeButton>
    </StackPanel>
</UserControl>
