<UserControl x:Class="GazeStream.Controls.LabeledSlider"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="0,6,0,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- Label -->
        <TextBlock Grid.Column="0" Grid.Row="0"
                   Text="{Binding Label, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   VerticalAlignment="Center" Foreground="Black"/>

        <!-- Slider -->
        <Slider Grid.Column="0" Grid.Row="1"
                Minimum="{Binding Minimum, RelativeSource={RelativeSource AncestorType=UserControl}}"
                Maximum="{Binding Maximum, RelativeSource={RelativeSource AncestorType=UserControl}}"
                Value="{Binding Value, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}"
                TickFrequency="{Binding TickFrequency, RelativeSource={RelativeSource AncestorType=UserControl}}"
                IsSnapToTickEnabled="{Binding IsSnapToTickEnabled, RelativeSource={RelativeSource AncestorType=UserControl}}"/>

        <!-- Value -->
        <TextBlock Grid.Column="1" Grid.Row="1"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Center"
                   Foreground="Black"
Text="{Binding Value, RelativeSource={RelativeSource AncestorType=UserControl}, StringFormat=0.00}" />
    </Grid>
</UserControl>
