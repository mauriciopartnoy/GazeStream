<Page x:Class="GazeStream.Pages.OptionsMainMenuPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:GazeStream.Pages"
      Title="OptionsMainMenuPage" 
      xmlns:eye="clr-namespace:GazeStream.Eyetracker"
      xmlns:controls="clr-namespace:GazeStream.Controls"
      xmlns:settings="clr-namespace:GazeStream.AppData"
      mc:Ignorable="d" 
      d:DataContext="{d:DesignInstance Type=settings:Settings}"
      d:DesignHeight="1080" d:DesignWidth="1920"
      >

    <Grid>
        <eye:GazeButton Width="200" Height="200">
            <eye:GazeButton.Content>
                <Button Style="{StaticResource Gaze}" Click="ToInteraction">
                    <Button.Content>
                        <Grid>
                            <Image Width="64" Height="64" HorizontalAlignment="Center" VerticalAlignment="Center" Source="/Resources/Icons/power.png"/>
                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Bottom" FontSize="22" FontWeight="SemiBold" Text="Reiniciar"/>
                        </Grid>
                    </Button.Content>
                </Button>
            </eye:GazeButton.Content>
        </eye:GazeButton>
    </Grid>
</Page>
