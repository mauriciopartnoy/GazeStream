<UserControl x:Class="GazeStream.Pages.CursorSettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:GazeStream.Controls">

    <Grid Margin="24" Background="White">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT PANEL: SETTINGS -->
        <StackPanel Grid.Column="0" VerticalAlignment="Top">
            <StackPanel.Resources>
                <Style TargetType="{x:Type TextBlock}">
                    <Setter Property="Margin" Value="0,10,0,0"/>
                </Style>
                <Style TargetType="{x:Type StackPanel}">
                    <Setter Property="Margin" Value="10,10,0,0"/>
                </Style>
            </StackPanel.Resources>
            <TextBlock Text="Opciones de Puntero"
                       FontSize="20"
                       FontWeight="SemiBold"/>

            <!-- Color -->
            <StackPanel>
                <TextBlock Text="Color"/>
                <ComboBox ItemsSource="{Binding AvailableColors}" SelectedIndex="{Binding SelectedColorIndex, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="4">

                                <!-- Color preview -->
                                <Border Width="18"
                        Height="18"
                        CornerRadius="3"
                        Margin="0,0,8,0"
                        Background="{Binding Color}" />

                                <!-- Name -->
                                <TextBlock Text="{Binding Name}"
                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <!-- Size -->
            <controls:LabeledSlider
    Label="Size"
    Foreground="Black"
    Minimum="8"
    Maximum="64"
    TickFrequency="1"
    IsSnapToTickEnabled="True"
    Value="{Binding Size}" />

            <!-- Opacity -->
            <controls:LabeledSlider
    Label="Opacity"
    Foreground="Black"
    Minimum="0"
    Maximum="1"
    TickFrequency="0.05"
    ValueFormat="P0"
    Value="{Binding Opacity}" />

        </StackPanel>

        <!-- RIGHT PANEL: PREVIEW -->
        <Border Grid.Column="1"
                Margin="24,0,0,0"
                Background="#1E1E1E"
                CornerRadius="12"
                Padding="24">

            <Grid>
                <TextBlock Text="Preview"
                           Foreground="#888"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Top"/>
                <controls:GazeCursor HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <!-- Placeholder for gaze cursor -->
                <Canvas Width="200"
                        Height="200"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>

            </Grid>

        </Border>

    </Grid>
</UserControl>
