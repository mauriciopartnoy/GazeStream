<UserControl x:Class="GazeStream.Pages.InteractionSettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GazeStream.Pages"
             xmlns:controls="clr-namespace:GazeStream.Controls"
             >
    <Grid Background="White" Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" VerticalAlignment="Top">
            <StackPanel.Resources>
                <Style TargetType="{x:Type TextBlock}">
                    <Setter Property="Margin" Value="0,10,0,0"/>
                </Style>
                <Style TargetType="{x:Type StackPanel}">
                    <Setter Property="Margin" Value="10,10,0,0"/>
                </Style>
            </StackPanel.Resources>
            <TextBlock Text="Opciones de Puntero"
                   FontSize="20"
                   FontWeight="SemiBold"/>

                <controls:LabeledSlider
Label="Tiempo de Activación"
Foreground="Black"
Minimum="0"
Maximum="5"
TickFrequency=".1"
IsSnapToTickEnabled="True"
Value="{Binding TiempoDeActivacion}" />

                <controls:LabeledSlider
Label="Tiempo de Desactivación"
Foreground="Black"
Minimum="0"
Maximum="5"
TickFrequency=".1"
IsSnapToTickEnabled="True"
Value="{Binding TiempoDeDesactivacion}" />

                <controls:LabeledSlider
Label="Tiempo de inicio de activación"
Foreground="Black"
Minimum="0"
Maximum="5"
TickFrequency="0.1"
ValueFormat="P0"
Value="{Binding InicioDeActivacion}" />

                <controls:LabeledSlider
Label="Permanencia de fijaciones incompletas"
Foreground="Black"
Minimum="0"
Maximum="5"
TickFrequency=".1"
IsSnapToTickEnabled="True"
Value="{Binding Permanencia}" />
            </StackPanel>

    </Grid>
</UserControl>
